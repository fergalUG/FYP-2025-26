{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"],
      "@components": ["components"],
      "@components/*": ["components/*"],
      "@utils": ["utils"],
      "@utils/*": ["utils/*"],
      "@services": ["services"],
      "@services/*": ["services/*"],
      "@hooks": ["hooks"],
      "@hooks/*": ["hooks/*"],
      "@types": ["types"],
      "@types/*": ["types/*"],
      "@constants/*": ["constants/*"],
      "@theme": ["theme"],
      "@modules/*": ["../modules/*"],
      "@db": ["db"],
      "@db/*": ["db/*"]
    }
  }
}
